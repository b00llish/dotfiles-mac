# ---------- RDI-Statements Functions ----------



# rdi-comdata — parse a Comdata fuel-card statement PDF into an Excel workbook.
#
# Install:
#   echo 'source ~/Developer/Projects/rdi-statements/scripts/rdi-comdata.zsh' >> ~/.zshrc
#   source ~/.zshrc
#
# Usage:
#   rdi-comdata 2026-03-23                 # resolve invoice date → PDF in OneDrive
#   rdi-comdata /full/path/to/file.pdf     # explicit path
#   rdi-comdata 2026-03-23 --strict        # any warning exits non-zero
#   rdi-comdata 2026-03-23 --output-dir ~/Documents/ComdataXLS
#   rdi-comdata 'path/*.pdf'               # batch via shell glob (quote to defer)
#   rdi-comdata --help                     # delegates to the CLI's help

rdi-comdata() {
  local repo="$HOME/Developer/Projects/rdi-statements"
  local bin="$repo/.venv/bin/rdi-statements"
  local bills_dir="$HOME/Library/CloudStorage/OneDrive-RetailDeliveryService/CM - Shared/Comdata Bills"

  if [[ ! -x "$bin" ]]; then
    echo "rdi-comdata: CLI not found at $bin" >&2
    echo "rdi-comdata: run 'poetry install' in $repo first" >&2
    return 127
  fi

  # Ergonomic arg handling: if $1 is YYYY-MM-DD, resolve it to the PDF in
  # OneDrive by filename convention (invoice date = first 6 digits as YYMMDD).
  # Otherwise forward args verbatim so all of `rdi-statements comdata parse`'s
  # flags work (--strict, --output-dir, globs, etc.).
  local -a args=()
  if [[ $# -gt 0 && "$1" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
    local yymmdd="${1:2:2}${1:5:2}${1:8:2}"
    local -a matches
    # (N) = nullglob — empty array instead of literal pattern when no match
    matches=("$bills_dir"/XG035KM_CXAC0002.D.XG035.NA."$yymmdd".*.pdf(N))
    if (( ${#matches[@]} == 0 )); then
      echo "rdi-comdata: no PDF found for invoice date $1" >&2
      echo "rdi-comdata: looked for ${yymmdd} in $bills_dir" >&2
      return 2
    fi
    args=("${matches[1]}")
    shift
    args+=("$@")
  else
    args=("$@")
  fi

  (cd "$repo" && "$bin" comdata parse "${args[@]}")
}