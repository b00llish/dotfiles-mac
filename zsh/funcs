# ---------- RDI-Market-Profitability Functions ----------



# rdi-rev — run the stop-ledger (revenue) pipeline from anywhere.
#
# Install:
#   echo 'source ~/Developer/Projects/rdi-market-profitability/scripts/rdi-rev.zsh' >> ~/.zshrc
#   source ~/.zshrc
#
# Usage:
#   rdi-rev                            # uses the default week from run.py
#   rdi-rev 2026-03-21                 # shorthand: first arg is the week
#   rdi-rev --week 2026-03-21          # explicit flag
#   rdi-rev 2026-03-21 --no-upload     # dry-run (no S3 upload)
#   rdi-rev --help                     # delegates to run.py's argparse help

rdi-rev() {
  local repo="$HOME/Developer/Projects/rdi-market-profitability"
  local py="$repo/.venv/bin/python"

  if [[ ! -x "$py" ]]; then
    echo "rdi-rev: venv python not found at $py" >&2
    echo "rdi-rev: create the venv first (python3 -m venv .venv && .venv/bin/pip install -r requirements.txt)" >&2
    return 127
  fi

  # Ergonomic arg handling: if $1 matches YYYY-MM-DD, prepend --week.
  # Otherwise forward args verbatim so all of run.py's flags work.
  local -a args=()
  if [[ $# -gt 0 && "$1" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
    args=(--week "$1")
    shift
    args+=("$@")
  else
    args=("$@")
  fi

  (cd "$repo" && "$py" run.py "${args[@]}")
}


