# oh-my-zsh plugin selection. This array is read by oh-my-zsh.sh when it's
# sourced (after this file) in zshrc.symlink — order: this file → oh-my-zsh.sh.
#
# Standard plugins live in ~/.oh-my-zsh/plugins/<name>/
# Custom plugins live in $ZSH_CUSTOM/plugins/<name>/
#
# Keep this list short — every plugin slows shell startup.
plugins=(
  git       # gst, gco, glog, etc. aliases
  sublime   # `subl` shortcut
  z         # `z <partial-name>` jumps to frequently-used dirs
)

# Non-OMZ plugins (zsh-autosuggestions, zsh-syntax-highlighting, powerlevel10k)
# are sourced directly from $HOMEBREW_PREFIX at the end of zshrc.symlink.
